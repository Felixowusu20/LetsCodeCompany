generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model Member {
  id        String   @id @default(cuid())
  name      String
  role      String
  bio       String   @default("")
  image     String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BlogPost {
  id           String   @id @default(cuid())
  title        String
  excerpt      String
  content      String
  author       String
  date         String
  image        String   @default("")
  authorAvatar String   @default("")
  comments     Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Project {
  id          String   @id @default(cuid())
  title       String
  description String
  image       String   @default("")
  tags        String[] @default([])
  websiteUrl  String?
  downloadUrl String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Service {
  id          String   @id @default(cuid())
  title       String
  description String
  icon        String?  @db.Text
  image       String   @default("")
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Partner {
  id        String   @id @default(cuid())
  name      String
  logo      String
  website   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HeroSlide {
  id        String   @id @default(cuid())
  title     String
  subtitle  String
  image     String
  /// Optional direct video file URL (.mp4 / .webm). YouTube/Vimeo page URLs are not supported.
  videoUrl  String?
  cta       String   @default("Get Started")
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Client work / case studies shown on `/work`.
model ClientProject {
  id          String   @id @default(cuid())
  title       String
  description String
  projectUrl  String
  imageUrl    String   @default("")
  iconUrl     String?
  /// Optional Lucide icon name (e.g. `Globe`). Prefer `iconUrl` for consistent branding.
  iconLucide  String?
  clientName  String?
  year        Int?
  tags        String[] @default([])
  featured    Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum ContactStatus {
  NEW
  IN_PROGRESS
  CLOSED
}

enum ContactProjectType {
  WEB_APP
  MOBILE_APP
  BOTH
  OTHER_CONSULTING
}

model ContactSubmission {
  id             String             @id @default(cuid())
  name           String
  email          String
  phone          String
  company        String?
  projectType    ContactProjectType
  projectDetails String?
  message        String
  status         ContactStatus      @default(NEW)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
}

enum PartnerApplicationStatus {
  NEW
  IN_REVIEW
  APPROVED
  REJECTED
}

enum PartnershipType {
  TECHNOLOGY
  RESELLER
  AGENCY
  REFERRAL
  AFFILIATE
  STRATEGIC
  OTHER
}

enum CompanySize {
  SOLO
  SIZE_2_10
  SIZE_11_50
  SIZE_51_200
  SIZE_201_1000
  SIZE_1000_PLUS
}

enum PartnerTimeline {
  IMMEDIATELY
  WITHIN_30_DAYS
  WITHIN_90_DAYS
  EXPLORING
}

/// Submissions from the public "Become a partner" form (open on PartnerMarquee).
/// Visible to admins under /admin/partner-applications.
model PartnerApplication {
  id              String                   @id @default(cuid())
  // Company
  companyName     String
  website         String?
  industry        String?
  companySize     CompanySize
  headquarters    String?
  // Primary contact
  contactName     String
  contactRole     String?
  contactEmail    String
  contactPhone    String?
  // Partnership intent
  partnershipType PartnershipType
  goals           String
  audienceFit     String?
  expertise       String?
  timeline        PartnerTimeline
  budgetRange     String?
  referralSource  String?
  // Admin workflow
  status          PartnerApplicationStatus @default(NEW)
  notes           String?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
}

/// Singleton row that powers the About page and the homepage About section.
/// We always read/write the first row; missing fields fall back to defaults.
model AboutContent {
  id String @id @default(cuid())

  heroEyebrow  String @default("About ZeoFex")
  heroTitle    String @default("Powerful service design for modern product teams.")
  heroSubtitle String @default("We combine engineering, design, and strategy to build digital products that feel premium and scale effortlessly.")

  storyTitle      String   @default("Our Story")
  storyParagraphs String[] @default([])
  storyImage      String   @default("")

  missionTitle String @default("Our Mission")
  missionText  String @default("")
  missionImage String @default("")

  visionTitle String @default("Our Vision")
  visionText  String @default("")
  visionImage String @default("")

  valuesTitle    String @default("Our Values")
  valuesSubtitle String @default("The principles that guide our work and shape every customer experience.")
  /// Array of { title: string; desc: string; image: string }
  values         Json   @default("[]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Singleton row for site footer (company blurb, link columns, CTA, legal).
model FooterContent {
  id String @id @default(cuid())

  companyName String @default("ZeoFex")
  tagline     String @default("Building reliable websites, apps, AI tools, and digital platforms for modern teams.")

  exploreColumnTitle String @default("Explore")
  /// Array of { label: string; href: string }
  exploreLinks Json @default("[]")

  companyColumnTitle String @default("Company")
  /// Array of { label: string; href: string }
  companyLinks Json @default("[]")

  ctaTitle       String @default("Let us turn your ideas into reality")
  ctaBody        String @default("ready to start a project or just want to say hi? We are here to help you build something great.")
  ctaButtonLabel String @default("Book a Call")
  ctaButtonHref  String @default("/contact")

  copyrightText String @default("© 2026 ZeoFex. All rights reserved.")
  termsLabel    String @default("Terms & Conditions")
  termsHref     String @default("/terms")

  socialColumnTitle String @default("Follow us")
  /// Array of { platform: string; href: string; label?: string } — platform is a Simple Icons slug (x, facebook, instagram, …) or "other".
  socialLinks       Json   @default("[]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Singleton row for navbar + admin chrome logos (URLs from Cloudinary or /public).
model SiteBranding {
  id String @id @default(cuid())

  /// Navbar when the site UI is light (legacy default: /whitelog.jpeg).
  logoWhenUiLightUrl String @default("")
  /// Navbar when the site UI is dark (legacy default: /logo.jpeg).
  logoWhenUiDarkUrl  String @default("")
  /// Login / admin shell header (square mark). Falls back to logoWhenUiDarkUrl when empty.
  adminPanelLogoUrl  String @default("")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
